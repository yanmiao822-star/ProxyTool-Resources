#!name=微博&微博国际版净化[墨鱼版]
#!desc=移除微博国内版及国际版开屏广告、信息流广告、评论区推广、发现页轮播等冗余元素。
#!author=ddgksf2013 overtrees修改整理
#!homepage=https://t.me/ddgksf2021
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Weibo.png
#!tag=工具,yanmiao
#!system_version=17
#!loon_version=3.3.9(945)

[Rewrite]
# ======= 通用拦截 ======= #
^https?:\/\/(preload-click|preload-impression)\.uve\.weibo\.com\/(interface\/wbpullad\/wbpullad_click\.php|wbapplua\/get_wbpullad_log\.lua) url reject
^https?:\/\/sdkapp\.uve\.weibo\.com\/interface\/sdk\/sdkconfig\.php url reject

# ======= 微博国内版 ======= #
# 首页信息流可能感兴趣推广
^https?:\/\/api\.weibo\.cn\/\d\/statuses\/container_positive url reject-200
# 首页顶部弹窗
^https?:\/\/api\.weibo\.cn\/\d\/push\/info url reject-200
# 启动感兴趣弹窗
^https?:\/\/api\.weibo\.cn\/.*account\/recommend_interesttags url reject-dict
# 首页顶部直播推荐Tab
^https?:\/\/api\.weibo\.cn\/.*\/media_homelist url reject-200
# 搜索页默认填充词
^https?:\/\/api\.weibo\.cn\/.*finder\/searchbarchange url reject-200
# AD_Preload
^https?:\/\/api\.weibo\.cn\/\d\/ad\/preload url reject-dict
# 用户推荐弹窗
^https?:\/\/api\.weibo\.cn\/\d\/profile\/recommend_popuser url reject-dict
# 每日一次的开屏广告请求
^https?:\/\/boot.*weibo\.com\/v\d\/ad\/realtime url reject-200
# 去除底部超话栏表层浮icon及tips
^https?:\/\/api\.weibo\.cn\/.*discovery_home_bottom_getdotinfo url reject-dict
# 屏蔽首页左上角每日的弹窗tips
^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/push\/daily url reject-dict
# Spotlight
^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/hot\/hours_spotlight url reject-dict

# ======= 微博国际版 ======= #
# 趋势页热门影片
^https?:\/\/api\.weibo\.cn\/\d\/cardlist\?v_f=.*Weibo_intl url reject-dict
# 屏蔽hotsearch
^https?:\/\/weibointl\.api\.weibo\.c(n|om)\/portal\.php\?a=hot_search_users url reject-dict
# 屏蔽热推荐
^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/ad\/weibointl\? url reject-dict

[Script]
# ======= 通用脚本（微博国内版） ======= #
http-response ^https?:\/\/api\.weibo\.cn\/\d\/statuses\/container_detail script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博_详情页及评论区
http-response ^https?:\/\/api\.weibo\.cn\/\d\/groups\/allgroups\/v\d script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博_首页顶部homeExtend
http-response ^https?:\/\/boot.*weibo\.com\/v\d\/ad\/preload script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博_开屏广告预加载处理
http-response ^https?:\/\/api\.weibo\.cn\/\d\/\w{5}\/(statuses_unread_hot_timeline|timeline) script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博_未登陆状态下首页信息流处理
http-response ^https?:\/\/api\.weibo\.cn\/\d\/video\/tiny_stream_mid_detail script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博_视频信息处理
http-response ^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/\w{5}\/cardlist script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博_屏蔽发现页面搜索框热词
http-response ^https?:\/\/api\.weibo\.cn\/2\/\!\/client\/light_skin script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博_自定义tab皮肤
http-response ^https?:\/\/new\.vip\.weibo\.cn\/littleskin\/preview script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博_非会员设置tab皮肤
http-response ^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/(searchall|page\?|0flowpage) script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博_去广告以及去除各部分推广模块
http-response ^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/statuses/(unread_)?friends(/|_)timeline script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博_首页信息流
http-response ^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/groups\/timeline script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博_超话时间线
http-response ^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/statuses\/(container_timeline|unread_hot_timeline|extend|video_mixtimeline|unread_topic_timeline) script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博_各类时间线
http-response ^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/profile\/(me|container_timeline) script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博_个人主页
http-response ^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/video\/(community_tab|remind_info|tiny_stream_video_list) script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博_视频相关
http-response ^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/search\/(finder|container_timeline|container_discover) script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博_搜索相关
http-response ^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/(checkin\/show|\!\/live\/media_homelist|container\/get_item) script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博_其他页面
http-response ^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/cardlist script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博_cardlist

# ======= 微博国际版 ======= #
http-response ^https?:\/\/weibointl\.api\.weibo\.cn\/portal\.php\?a=open_app script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博国际版_帖子下方广告banner
http-response ^https?:\/\/weibointl\.api\.weibo\.c(n|om)\/portal\.php.*a=get_searching_info script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_search_info.json, requires-body=true, tag=微博国际版_屏蔽searching_info
http-response ^https?:\/\/weibointl\.api\.weibo\.c(n|om)\/portal\.php.*feed&a=search_topic script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_search_topic.json, requires-body=true, tag=微博国际版_屏蔽search_topic
http-response ^https?:\/\/weibointl\.api\.weibo\.c(n|om)\/portal\.php.*get_coopen_ads script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博国际版_屏蔽开屏广告
http-response ^https?:\/\/(sdk|wb)app\.uve\.weibo\.com(\/interface\/sdk\/sdkad\.php|\/wbapplua\/wbpullad\.lua) script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博国际版_屏蔽sdkad
http-response ^https?:\/\/weibointl\.api\.weibo\.c(n|om)\/portal\.php.*a=trends script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博国际版_趋势顶部Card去广告
http-response ^https?:\/\/weibointl\.api\.weibo\.cn\/portal\.php\?a=user_center script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博国际版_屏蔽用户VIP栏
http-response ^https?:\/\/weibointl\.api\.weibo\.cn\/portal\.php\?a=search_topic script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, tag=微博国际版_热搜处理

[MITM]
hostname = %APPEND% api.weibo.cn, m.api.weibo.cn, api.weibo.com, *.api.weibo.cn, *.api.weibo.com, mapi.weibo.com, *.uve.weibo.com, new.vip.weibo.cn, boot.biz.weibo.com, boot.*.weibo.com, weibointl.api.weibo.cn, weibointl.api.weibo.com, *.uve.weibo.com